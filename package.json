{
	"name": "pi-gateway-standalone",
	"version": "0.57.1",
	"description": "Pi Gateway - Standalone version (independent from monorepo)",
	"type": "module",
	"bin": {
		"pi-gateway": "dist/server.js"
	},
	"main": "./dist/server.js",
	"types": "./dist/server.d.ts",
	"exports": {
		".": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		}
	},
	"files": [
		"dist",
		"public",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"dev": "tsx watch src/server.ts",
		"dev:react": "vite",
		"build": "vite build --logLevel warn",
		"build:ci": "vite build --logLevel error --mode production",
		"build:server": "tsc -p tsconfig.json",
		"start": "node dist/server.js",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit --skipLibCheck",
		"check:ci": "biome check --error-on-warnings . && tsc --noEmit --skipLibCheck",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.react.json --noEmit",
		"test": "vitest --run test/unit test/integration src/",
		"test:unit": "vitest --run test/unit",
		"test:integration": "vitest --run test/integration",
		"test:e2e": "vitest --run test/e2e",
		"test:debug": "vitest --run test/debug",
		"test:all": "vitest --run test/",
		"test:browser:install": "playwright install chromium",
		"preview": "vite preview"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@mariozechner/pi-agent-core": "^0.57.1",
		"@mariozechner/pi-ai": "^0.57.1",
		"@mariozechner/pi-coding-agent": "^0.57.1",
		"@tanstack/react-query": "^5.95.2",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/helmet": "^0.0.48",
		"@types/morgan": "^1.9.10",
		"@types/prismjs": "^1.26.6",
		"@types/react-window": "^1.8.8",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"chalk": "^5.5.0",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"express": "^4.18.2",
		"helmet": "^8.1.0",
		"morgan": "^1.10.1",
		"prismjs": "^1.30.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^16.1.1",
		"react-window": "^2.2.7",
		"ws": "^8.16.0",
		"zod": "^3.22.4",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@playwright/test": "^1.58.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/express": "^4.17.21",
		"@types/node": "^20.19.37",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.5.10",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^1.2.0",
		"esbuild": "^0.27.4",
		"esbuild-plugin-ts": "^0.1.1-rev-1.0",
		"jsdom": "^29.0.1",
		"playwright": "^1.41.0",
		"rollup": "^4.60.0",
		"tsx": "^4.7.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.2",
		"vitest": "^1.2.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
